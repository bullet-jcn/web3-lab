# Alchemy API key — https://dashboard.alchemy.com
# 同一个 key 通用于 Ethereum / Base 的主网与测试网，
# 具体如何拼出各链的 RPC URL 见 lib/rpc.ts
NEXT_PUBLIC_ALCHEMY_API_KEY=your-alchemy-api-key

# 服务端专用（不加 NEXT_PUBLIC_ 前缀，不会被打进浏览器 bundle）
# 用于给 SIWE nonce / session cookie 签名，生成方式：openssl rand -base64 32
AUTH_COOKIE_SECRET=your-random-secret
